# Configuration for the Headplane server and web application
server:
  host: "0.0.0.0"
  port: 3000
  base_url: "https://headplane.{{ public_dns }}"
  cookie_secret: "{{ headplane_cookie_secret | default('<change_me_to_something_secure!>') }}"
  cookie_secure: true
  cookie_max_age: 86400
  data_path: "/var/lib/headplane"

# Headscale specific settings to allow Headplane to talk
# to Headscale and access deep integration features
headscale:
  # In-cluster service URL
  url: "http://headscale:8080"
  public_url: "https://headscale.{{ public_dns }}"
  api_key: "{{ headplane_headscale_api_key }}"
  config_strict: false

oidc:
  enabled: true
  headscale_api_key: "{{ headplane_headscale_api_key }}"
  issuer: "https://accounts.google.com"
  client_id: "{{ headplane_client_id }}"
  client_secret: "{{ headplane_client_secret }}"
  scope: "openid email profile"
  use_pkce: true

# Integration configurations for Headplane to interact with Headscale
integration:
  agent:
    enabled: false
    pre_authkey: "{{ headplane_agent_preauthkey }}"

  docker:
    enabled: false
    container_label: "me.tale.headplane.target=headscale"
    socket: "unix:///var/run/docker.sock"

  kubernetes:
    enabled: false
    validate_manifest: true
    pod_name: "headscale"

  proc:
    enabled: false
